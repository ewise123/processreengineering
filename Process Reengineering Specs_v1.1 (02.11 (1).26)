10. Deployment Architecture (Render)
10.1 Services
# render.yaml

services:
  # Frontend
  - type: web
    name: pra-frontend
    env: static
    buildCommand: npm run build
    staticPublishPath: ./dist
    headers:
      - path: /*
        name: X-Frame-Options
        value: DENY

  # Backend API
  - type: web
    name: pra-api
    env: python
    buildCommand: pip install -r requirements.txt
    startCommand: uvicorn main:app --host 0.0.0.0 --port $PORT
    healthCheckPath: /health
    envVars:
      - key: DATABASE_URL
        fromDatabase:
          name: pra-db
          property: connectionString
      - key: REDIS_URL
        fromService:
          name: pra-redis
          type: redis
          property: connectionString
      - key: ANTHROPIC_API_KEY
        sync: false
      - key: AUTH0_DOMAIN
        sync: false
      - key: AUTH0_CLIENT_ID
        sync: false

  # Celery Worker
  - type: worker
    name: pra-worker
    env: python
    buildCommand: pip install -r requirements.txt
    startCommand: celery -A tasks worker --loglevel=info
    envVars:
      - key: DATABASE_URL
        fromDatabase:
          name: pra-db
          property: connectionString
      - key: REDIS_URL
        fromService:
          name: pra-redis
          type: redis
          property: connectionString

databases:
  - name: pra-db
    plan: standard

redis:
  - name: pra-redis
